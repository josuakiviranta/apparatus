{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react"
  },
  "include": ["src/cli/**/*", "src/daemon/**/*"],
  "exclude": ["node_modules", "dist", "src/cli/tests", "src/daemon/tests"]
}
