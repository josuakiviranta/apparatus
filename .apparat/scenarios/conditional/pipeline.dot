digraph conditional_smoke {
  goal="Smoke test: diamond conditional node routing on context variable"

  start [shape=Mdiamond]

  // Agent node produces structured output with a "result" field
  classify [
    agent="classify"
  ]

  // Diamond node routes based on context variable set by classify
  router [shape=diamond]

  pass_path [
    agent="pass-handler"
  ]

  fail_path [
    agent="fail-handler"
  ]

  done [shape=Msquare]

  start     -> classify
  classify  -> router
  router    -> pass_path [condition="classify.result=pass"]
  router    -> fail_path [condition="classify.result=fail"]
  pass_path -> done
  fail_path -> done
}
