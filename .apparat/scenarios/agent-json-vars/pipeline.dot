digraph agent_json_vars_smoke {
  goal="Smoke test: agent JSON output variables consumed by downstream node"

  start [shape=Mdiamond]

  // Agent produces JSON with two fields
  producer [
    agent="producer"
  ]

  // Downstream agent consumes producer.result and producer.label via auto-injected Inputs block
  consumer [
    agent="consumer"
  ]

  done [shape=Msquare]

  start -> producer -> consumer -> done
}
