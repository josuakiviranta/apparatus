digraph chat_end_to_end {
  start [shape=Mdiamond];

  chat [
    agent="chat",
    interactive=true
  ];

  summarize [
    agent="summarize"
  ];

  recovery [
    agent="recovery",
    default_output=""
  ];

  done [shape=Msquare];

  start     -> chat;
  chat      -> summarize [condition="outcome=success"];
  chat      -> recovery  [condition="outcome=fail"];
  summarize -> done;
  recovery  -> done;
}
