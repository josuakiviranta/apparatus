digraph gate_smoke {
  goal="Smoke test: gate node with two labeled choices"

  start [shape=Mdiamond]

  gate [shape=hexagon, label="Pick a path:\n\nA: Proceed  B: Abort"]

  proceed [
    agent="proceed"
  ]

  abort [
    agent="abort"
  ]

  done [shape=Msquare]

  start   -> gate
  gate    -> proceed [label="Proceed"]
  gate    -> abort   [label="Abort"]
  proceed -> done
  abort   -> done
}
