digraph agent_json_vars_smoke {
  goal="Smoke test: agent JSON output variables consumed by downstream node"

  start [shape=Mdiamond]

  // Agent produces JSON with two fields
  producer [
    agent="task",
    json_schema_file="schemas/agent-json-vars.json",
    prompt="Return JSON with exactly: { \"result\": \"hello\", \"label\": \"world\" }. Do NOT use any tools."
  ]

  // Downstream agent consumes $result and $label from producer output
  consumer [
    agent="task",
    prompt="The result is '$result' and the label is '$label'. Output exactly one line: 'agent-json-vars: ok'. Do NOT use any tools."
  ]

  done [shape=Msquare]

  start -> producer -> consumer -> done
}
