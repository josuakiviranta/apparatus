digraph tmux_tester_smoke {
  graph [goal="Verify an agent can drive ralph meditate in a tmux window and summarise the resulting illumination for a 5-year-old"]

  start [shape=Mdiamond]

  launch_tmux [type="tool", cwd="$project", tool_command="tmux new-window -c \"$project\" -n \"pipe-tmux-tester-inner-$run_id\""]

  tmux_meditate_observer [agent="implement", json_schema_file="../schemas/meditate-observe.json", produces="topic, illumination_path, kid_summary, observation_notes", prompt="Read docs/harness/tmux-drive.md first — it has the authoritative bash harness patterns (source the block).\n\nA tmux window named 'pipe-tmux-tester-inner-$run_id' was just opened in the current session, cwd set to project $project.\n\nYour task: drive 'ralph meditate' in that window, observe it, then summarise the resulting illumination for a 5-year-old.\n\nSteps:\n1. Source the harness helpers from docs/harness/tmux-drive.md.\n2. Set SESSION=$(tmux display-message -p '#S') and WIN=pipe-tmux-tester-inner-$run_id.\n3. Pick a topic from the current project state. Run 'git log -5 --oneline' and 'git status --short' to see recent activity, then choose one short sentence describing something to reflect on (e.g. 'Reflect on the recent ralph pipeline refine command work and what it changed about agent-assisted iteration'). Do not explore deeply — pick fast.\n4. Send into the window via the harness: ralph meditate . --steer \"<your topic>\"\n5. Wait for the meditation to finish. Detection: the file '$project/.meditate.pid' is written while meditate is alive and removed on exit. Poll every 10s with a 600000ms (10min) budget. In parallel capture_pane occasionally so you can describe what you saw in the TUI.\n6. After pid file is gone: list 'meditations/illuminations/' sorted by mtime, take the newest file, read it.\n7. Produce the four schema fields:\n   - topic: the sentence you passed to --steer\n   - illumination_path: relative path to the newest illumination file\n   - kid_summary: 3-5 short sentences explaining the illumination like to a 5-year-old. No jargon. No code. Plain words.\n   - observation_notes: 1-2 sentences describing what the meditate TUI showed (which phases you saw, roughly how long it ran).\n\nRules:\n- Do NOT run 'ralph meditate' yourself synchronously — only via tmux send_keys so it runs inside the window.\n- Do NOT git push or modify source files.\n- Do NOT cancel the meditation early."]

  done [shape=Msquare]

  start -> launch_tmux
  launch_tmux -> tmux_meditate_observer
  tmux_meditate_observer -> done
}
