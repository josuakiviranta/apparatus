digraph illumination_to_implementation {
  goal="Triage an illumination into an approved design doc, implementation plan, and committed code"
  headless_safe=false
  inputs="project, meditations_dir, specs_dir, plans_dir"

  start [shape=Mdiamond]

  // ── Phase 1: Illumination triage (from illumination-to-plan) ──────────────

  verifier [agent="implement", json_schema_file="schemas/verifier.json", produces="preferred_label, illumination_path, summary, explanation", prompt="You are a verification agent for the ralph-cli project.\n\n## Task\n\n1. Run glob on $meditations_dir/illuminations/*.md to list all illumination files.\n2. For each candidate, read its frontmatter. Consider ONLY files whose frontmatter `status` field is `open` (or is absent — treat missing status as open). SKIP any file with `status: dispatched`, `status: archived`, or any other non-open value — those have already been triaged and must not be re-processed.\n3. If no open illuminations remain, return preferred_label: empty, illumination_path: empty, summary: No open illuminations found, explanation: All illuminations in the directory are dispatched, archived, or otherwise closed.\n4. Pick ONE open illumination to verify. Read it carefully.\n5. Spawn subagents (up to 50) to verify the illumination against the current codebase:\n   - Check src/ to verify technical claims about code behavior\n   - Check specs/*.md to verify claims about specifications\n   - Verify the issue described has NOT already been fixed\n6. Return your structured verdict.\n\n## Verification Criteria\n- Still relevant: the issue or gap described in the illumination exists in the current code\n- Technically accurate: the claims about code behavior match what the source code actually does\n- Both must be true for preferred_label: true\n\n## Rules\n- Do NOT modify any project files\n- Read only — no edits, no deletions, no new files"]

  explain_removal [agent="implement", prompt="Read the illumination at $illumination_path.\n\nVerifier explanation: $explanation\n\nIn ONE sentence, explain to the user why this illumination is no longer valid or technically inaccurate. Be specific — reference the code or spec that contradicts it.\n\nDo NOT modify any project files."]

  remove_gate [shape=hexagon, label="Remove this illumination?\n$illumination_path\n\n$explanation"]

  delete_file [type="tool", cwd="$project", tool_command="rm $illumination_path"]

  mark_archived [agent="implement", default_refinements="", prompt="Call mcp__illumination__mark_archived with filename from $illumination_path (basename only) and a reason summarizing why the illumination is being archived.\n\nContext sources (combine into one concise reason):\n- Illumination summary: $summary\n- Verifier explanation: $explanation\n- Chat refinements (if any): $refinements\n\nReturn the JSON result."]

  mark_dispatched [type="tool",
                   cwd="$project",
                   script_file="scripts/mark-dispatched.mjs",
                   script_args="$illumination_path $plan_path"]

  explainer [agent="implement", prompt="Read the illumination at $illumination_path.\n\nVerifier summary: $summary\nVerifier explanation: $explanation\n\nYour job: explain the change in plain language using CONCRETE examples drawn from the current codebase. Spawn subagents (up to 10) to gather context — read the source files, specs, CLI output patterns, or command shapes referenced in the illumination. Quote real paths, snippets, and command strings verbatim. Do not guess.\n\nProduce four sections:\n1. **Currently implemented** — show a concrete before-example: a real command invocation + its output today, or a code snippet from the cited file. Quote verbatim with file:line citations.\n2. **What will change** — show the same example after the change: the new command shape / new output / new code. Side-by-side with the before block.\n3. **Why it matters** — one sentence tying the diff to user-visible value.\n4. **Affected files** — bullet list of paths.\n\nA before/after code block beats prose. Aim for clarity over brevity. Do NOT modify any project files."]

  approval_gate [shape=hexagon, default_refinements="", label="Proceed with plan?\n\nIllumination: $illumination_path\nSummary: $summary\n\nRefinements (empty on first entry):\n$refinements"]

  chat_session [agent="implement", interactive=true, prompt="You are discussing an illumination with the user.\n\nIllumination file: $illumination_path\nSummary: $summary\nExplanation: $explanation\n\nThe user may want to:\n- Refine the scope of changes\n- Add constraints or requirements\n- Ask questions about the illumination\n- Disagree with the assessment\n\nBefore ending the conversation, write your agreed conclusions to $meditations_dir/.triage/$run_id/chat-notes.md. This file will be read by the next pipeline stage.\n\nDo NOT modify any other project files."]

  chat_summarizer [agent="implement", default_refinements="", json_schema_file="schemas/chat-summarizer.json", produces="refinements, scope_changed, chat_notes_path", prompt="Read $meditations_dir/.triage/$run_id/chat-notes.md and the illumination at $illumination_path.\n\nOriginal summary: $summary\nOriginal explanation: $explanation\nPrevious refinements (if any): $refinements\n\nSummarize what was refined or changed during the interactive session. Focus on concrete changes to scope, constraints, or approach.\n\nEmit chat_notes_path set to exactly: $meditations_dir/.triage/$run_id/chat-notes.md — downstream nodes read the raw notes for full context.\n\nDo NOT modify any project files."]

  design_writer [agent="implement", default_refinements="No interactive refinements were requested.", default_chat_notes_path="", json_schema_file="schemas/design-writer.json", produces="design_doc_path", prompt="Write a superpowers-style design document for the approved illumination.\n\nIllumination: $illumination_path\nSummary: $summary\nExplanation: $explanation\nRefinements: $refinements\nChat notes: $chat_notes_path\n\n## Required workflow\n1. If $chat_notes_path is non-empty, read that file first — it contains the full interactive-session context (rejected approaches, precedents cited, reasoning) that the summarizer distilled into $refinements. Prefer the raw notes over the summary where they conflict.\n2. Invoke the superpowers:brainstorming skill via the Skill tool to load its conventions. Skip the interactive Q&A phase — upstream nodes already refined intent. Jump to the 'After the Design' section.\n3. Write the initial design doc to $specs_dir/YYYY-MM-DD-<topic>-design.md (today's date, short kebab-case topic derived from the illumination). Follow the conventions of existing design docs in $specs_dir/. Cover: overview, architecture, components, data flow, constraints.\n4. Run the brainstorming skill's **Spec Review Loop**: dispatch the spec-document-reviewer subagent (see the skill's spec-document-reviewer-prompt.md) and pass the draft + illumination context. If the reviewer returns ❌ Issues Found, fix them in-place and re-dispatch. Stop on ✅ Approved or after 5 iterations (surface to user if stuck).\n5. Return the final file path in your structured output.\n\nDo NOT modify any other project files."]

  plan_writer [agent="implement", default_refinements="No interactive refinements were requested.", default_chat_notes_path="", json_schema_file="schemas/plan-writer.json", produces="plan_path", prompt="Read the design doc at $design_doc_path — it is the primary source of truth.\n\nSupporting context (consult only if the design doc is missing a detail):\n- Illumination: $illumination_path\n- Refinements from chat: $refinements\n- Chat notes: $chat_notes_path (read if non-empty for edge-cases, test scenarios, or constraints the user raised that did not land in the design doc)\n\n## Required workflow\n1. Invoke the superpowers:writing-plans skill via the Skill tool and follow it end-to-end.\n2. Write the initial plan to $plans_dir/YYYY-MM-DD-<topic>.md where date and topic match the design doc. Use the skill's required plan header. Structure the plan with '## Chunk N: <name>' headings (each chunk ≤1000 lines, logically self-contained). Tasks follow bite-sized TDD steps with exact file paths, full code blocks, exact commands, expected output, and commit messages.\n3. Run the skill's **Plan Review Loop** per chunk: dispatch the plan-document-reviewer subagent (see the skill's plan-document-reviewer-prompt.md) with that chunk's content + the path to the design doc. If ❌ Issues Found, fix the chunk and re-dispatch. Advance to the next chunk only on ✅ Approved. Max 5 iterations per chunk (surface to user if stuck).\n4. Return the final file path in your structured output.\n\nDo NOT modify any other project files."]

  // ── Phase 2: Implementation ───────────────────────────────────────────────

  implement [agent="implement", max_retries=1, retry_target="implement", prompt="Read the implementation plan at $plan_path.\n\nImplement the plan using red/green TDD:\n1. Read the plan carefully\n2. For each chunk: write failing tests first, then implement to make them pass\n3. Commit after each passing chunk\n\nDo NOT push — a separate pipeline node handles that.\nDo NOT modify files outside the scope of the plan."]

  implement_retry [agent="implement", default_test_result="", default_test_summary="", prompt="Read the implementation plan at $plan_path.\n\nThe previous implementation attempt was tested in a tmux window. Prior run result: $test_result\n\nPrior test summary:\n$test_summary\n\nPrioritize fixing the specific failures reported above. Implement using red/green TDD:\n1. Inspect the failing tests or build errors cited in the summary\n2. Write or update tests that reproduce the specific failure\n3. Implement the fix to make those tests pass\n4. Commit after each passing chunk\n\nDo NOT push — a separate pipeline node handles that.\nDo NOT modify files outside the scope of the plan."]

  review_gate [shape=hexagon, label="Review implementation\n\nProject: $project\nPlan: $plan_path"]

  launch_tmux [type="tool", cwd="$project", tool_command="tmux new-window -c \"$project\" -n \"test-$run_id\""]

  tmux_tester [agent="tmux-tester", json_schema_file="schemas/tmux-test-result.json", produces="test_result, test_summary, issues_found"]

  tmux_confirm_gate [shape=hexagon, label="Tests ran in tmux window.\nResult: $test_result\n\n$test_summary\n\nReview then decide."]

  commit_push [type="tool", cwd="$project", tool_command="git push origin $(git branch --show-current) || git push -u origin $(git branch --show-current)"]

  memory_writer [agent="implement", default_test_result="", default_test_summary="", prompt="Write a memory file documenting this implementation session.\n\nPlan implemented: $plan_path\nDesign doc: $design_doc_path\nIllumination: $illumination_path\n\nSession outcome (empty if implementation skipped tmux verification):\n- Final test result: $test_result\n- Final test summary: $test_summary\n\nWrite to $project/memory/YYYY-MM-DD-<topic>.md where the date is today and topic is a short kebab-case name matching the plan.\n\nInclude:\n- What was implemented (1-2 sentences)\n- Key files created or modified\n- Important decisions made or patterns established\n- Any gotchas or constraints discovered during implementation\n- If test_result/test_summary are non-empty, record the final tmux verification outcome and any retry history discoverable from git log\n\nKeep it concise — this is a reference for future sessions, not a full report."]

  done [shape=Msquare]

  // ── Routing: Phase 1 ─────────────────────────────────────────────────────
  start -> verifier
  verifier -> explain_removal  [condition="preferred_label=false"]
  verifier -> explainer        [condition="preferred_label=true"]
  verifier -> done             [condition="preferred_label=empty"]

  // False path
  explain_removal -> remove_gate
  remove_gate -> done         [label="No"]
  remove_gate -> delete_file  [label="Yes"]
  delete_file -> done

  // True path
  explainer -> approval_gate
  approval_gate -> mark_archived  [label="Decline"]
  approval_gate -> design_writer  [label="Approve"]
  approval_gate -> chat_session   [label="Chat"]

  // Chat loop
  chat_session -> chat_summarizer -> approval_gate

  // Decline branch terminator
  mark_archived -> done

  // Plan writing — plan_writer must run before mark_dispatched so the
  // illumination frontmatter can record the resulting $plan_path.
  design_writer -> plan_writer -> mark_dispatched

  // ── Routing: Phase 2 ─────────────────────────────────────────────────────
  mark_dispatched -> implement

  implement -> implement           [condition="agent.success=false"]
  implement -> review_gate
  implement_retry -> review_gate
  review_gate -> commit_push       [label="Approve"]
  review_gate -> launch_tmux       [label="Tmux"]
  review_gate -> implement         [label="Retry"]

  launch_tmux -> tmux_tester
  tmux_tester -> tmux_confirm_gate
  tmux_confirm_gate -> commit_push [label="Commit"]
  tmux_confirm_gate -> implement_retry [label="Retry"]

  commit_push -> memory_writer -> done
}
