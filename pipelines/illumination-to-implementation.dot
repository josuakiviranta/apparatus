digraph illumination_to_implementation {
  goal="Triage an illumination into an approved design doc, implementation plan, and committed code"
  headless_safe=false
  inputs="project, illuminations_dir, specs_dir, plans_dir"

  start [shape=Mdiamond]

  // ── Phase 1: Illumination triage (from illumination-to-plan) ──────────────

  verifier [agent="verifier", json_schema_file="schemas/verifier.json", produces="preferred_label, illumination_path, summary, explanation", prompt="Verify one illumination from $illuminations_dir/illuminations/*.md against the current ralph-cli codebase.\n\nFollow your agent-level rubric (relevance + technical accuracy + project-fit / Feature-Creep) and procedure. Use $illuminations_dir as the input directory. Project root for README and specs lookup is the current working directory.\n\nReturn the structured verdict only — no prose preamble."]

  remove_gate [shape=hexagon, label="Archive this illumination?\n$illumination_path\n\n$explanation"]

  mark_archived [type="tool",
                 cwd="$project",
                 script_file="scripts/mark-archived.mjs",
                 script_args="$illumination_path $choice"]

  mark_dispatched [type="tool",
                   cwd="$project",
                   script_file="scripts/mark-dispatched.mjs",
                   script_args="$illumination_path $plan_path"]

  explainer [agent="change-explainer", default_refinements="", json_schema_file="schemas/explainer.json", produces="explainer_render", prompt="Render a before/after explainer for the verified illumination.\n\nIllumination: $illumination_path\nVerifier summary: $summary\nVerifier explanation: $explanation\nRefinements (cumulative; empty on first pass):\n$refinements\n\nFollow your agent-level format and procedure. Use up to 10 subagents to pull verbatim evidence. Return only the structured JSON with the explainer_render field."]

  approval_gate [shape=hexagon, default_refinements="", label="Proceed with plan?\n\nIllumination: $illumination_path\nSummary: $summary\nVerifier: $explanation\n\n$explainer_render\n\nRefinements (cumulative; empty on first entry):\n$refinements"]

  chat_session [agent="chat-refiner", interactive=true, default_refinements="", prompt="Discuss the illumination with the user.\n\nIllumination: $illumination_path\nSummary: $summary\nVerifier explanation: $explanation\nPrior refinements (empty on first chat round):\n$refinements\n\nWrite agreed conclusions to: $illuminations_dir/.triage/$run_id/chat-notes.md\n\nFollow your agent-level format and append rule. Do NOT modify any other project files."]

  chat_summarizer [agent="implement", default_refinements="", json_schema_file="schemas/chat-summarizer.json", produces="refinements, scope_changed", prompt="Read $illuminations_dir/.triage/$run_id/chat-notes.md and the illumination at $illumination_path.\n\nOriginal summary: $summary\nOriginal explanation: $explanation\nPrior refinements (cumulative log from earlier rounds; empty on first round):\n$refinements\n\n## Required output\n\nEmit refinements as a CUMULATIVE markdown bullet log. Every bullet must include attribution so downstream agents (design_writer, plan_writer) can judge whether to honor the refinement and why. Per-bullet shape:\n\n- <refinement statement>\n  - Round: <N> (1 for first chat round, increment per re-entry)\n  - Topic raised by user: <what the user said, near-verbatim>\n  - Rationale: <user's stated reason>\n\nMERGE rules:\n- Re-emit every bullet from prior $refinements verbatim (do NOT drop or paraphrase prior entries)\n- Append new bullets from the latest chat-notes.md round below them\n- If the latest round CONTRADICTS a prior bullet, keep the prior bullet but add a new bullet noting the override and rationale (do not silently delete history)\n\nSet scope_changed=true only if the latest round materially altered scope (new files in/out, new behavior, removed behavior). Cosmetic clarifications do not flip the flag.\n\nDo NOT modify any project files."]

  design_writer [agent="design-writer", default_refinements="No interactive refinements were requested.", json_schema_file="schemas/design-writer.json", produces="design_doc_path", prompt="Write a design doc for the approved illumination.\n\nIllumination: $illumination_path\nVerifier summary: $summary\nVerifier explanation: $explanation\nApproved explainer render:\n$explainer_render\nRefinements (cumulative log with per-bullet attribution):\n$refinements\n\nFollow your agent-level procedure: derive the design-doc filename from the illumination slug, invoke superpowers:brainstorming, write to $specs_dir/, then loop with the spec-document-reviewer subagent until you both agree the doc is ready (no iteration cap). Return the structured JSON with the design_doc_path field only."]

  plan_writer [agent="plan-writer", default_refinements="No interactive refinements were requested.", json_schema_file="schemas/plan-writer.json", produces="plan_path", prompt="Write a chunked TDD implementation plan for the approved design.\n\nDesign doc (primary source of truth): $design_doc_path\nIllumination: $illumination_path\nRefinements (cumulative log with per-bullet attribution):\n$refinements\n\nFollow your agent-level procedure: derive the plan filename from the illumination slug, invoke superpowers:writing-plans, write to $plans_dir/, then loop with the plan-document-reviewer subagent per chunk until you both agree each chunk is ready (no iteration cap). Return the structured JSON with the plan_path field only."]

  // ── Phase 2: Implementation ───────────────────────────────────────────────

  implement [agent="implement", max_retries=1, prompt="Read the implementation plan at $plan_path.\n\nImplement the plan using red/green TDD:\n1. Read the plan carefully\n2. For each chunk: write failing tests first, then implement to make them pass\n3. Commit after each passing chunk\n\nDo NOT push — a separate pipeline node handles that.\nDo NOT modify files outside the scope of the plan."]

  review_gate [shape=hexagon, label="Review implementation\n\nProject: $project\nPlan: $plan_path"]

  tmux_tester [agent="tmux-tester", json_schema_file="schemas/tmux-test-result.json", produces="test_result, test_summary, issues_found, test_render", prompt="Open (or reuse) a tmux window named `test-$run_id` in project $project, then drive it through build/test/smoke cycles. When a cycle surfaces a fixable issue, apply a red/green TDD fix in-session and commit it (no push — commit_push handles that). Repeat cycles until the project is healthy or remaining issues are beyond what you can fix this session.\n\nRun id to use for the window name and harness binding: $run_id\n\nFollow your agent-level procedure and harness helpers. Stop based on context, not a counter. Emit the structured JSON with test_result, test_summary, issues_found, and a scannable markdown test_render for the approval gate."]

  tmux_confirm_gate [shape=hexagon, label="Tests ran in tmux window test-$run_id.\n\n$test_render\n\nCommit the fixes or give tmux-tester another pass?"]

  memory_writer [agent="memory-writer", default_test_result="", default_test_summary="", json_schema_file="schemas/memory-writer.json", produces="memory_path", prompt="Close out the pipeline session.\n\nRun id: $run_id\nProject: $project\nPlan: $plan_path\nDesign doc: $design_doc_path\nIllumination: $illumination_path\nFinal test result (empty if tmux verification was skipped): $test_result\nFinal test summary: $test_summary\n\nFollow your agent-level procedure:\n1. Derive the memory filename from the plan slug → $project/memory/YYYY-MM-DD-<slug>.md.\n2. Read the pipeline trace at ~/.ralph/runs/$run_id/pipeline.jsonl. Scan it for node retries, tmux-tester fix cycles, and tool-node failures — these feed the optional Learnings section.\n3. Read the design doc, plan, illumination, and recent git log for grounding.\n4. Write the memory file using the structure in your agent file (frontmatter + What was implemented / Key files / Decisions / Gotchas / Learnings / Final verification). Include the Learnings section only if the trace shows real struggles — no padding.\n5. cd $project; git add -A; commit if anything is staged; then git push -u origin $(git branch --show-current) unconditionally (prior implement/tmux-tester commits may need to reach origin).\n6. Return structured JSON with memory_path."]

  done [shape=Msquare]

  // ── Routing: Phase 1 ─────────────────────────────────────────────────────
  start -> verifier
  verifier -> remove_gate      [condition="preferred_label=false"]
  verifier -> explainer        [condition="preferred_label=true"]
  verifier -> done             [condition="preferred_label=empty"]

  // False path
  remove_gate -> done           [label="Skip"]
  remove_gate -> mark_archived  [label="Archive"]

  // True path
  explainer -> approval_gate
  approval_gate -> mark_archived  [label="Decline"]
  approval_gate -> design_writer  [label="Approve"]
  approval_gate -> chat_session   [label="Chat"]

  // Chat loop — re-render explainer with refinements before re-prompting at gate.
  // When the chat materially alters scope, loop back through verifier so $summary
  // and $explanation reflect the refined scope, not the original illumination pass.
  chat_session -> chat_summarizer
  chat_summarizer -> verifier  [condition="scope_changed=true"]
  chat_summarizer -> explainer [condition="scope_changed=false"]

  // Decline branch terminator
  mark_archived -> done

  // Plan writing — plan_writer must run before mark_dispatched so the
  // illumination frontmatter can record the resulting $plan_path.
  design_writer -> plan_writer -> mark_dispatched

  // ── Routing: Phase 2 ─────────────────────────────────────────────────────
  mark_dispatched -> implement

  implement -> implement           [condition="agent.success=false"]
  implement -> review_gate
  review_gate -> memory_writer     [label="Approve"]
  review_gate -> tmux_tester       [label="Tmux"]
  review_gate -> implement         [label="Retry"]

  tmux_tester -> tmux_confirm_gate
  tmux_confirm_gate -> memory_writer [label="Commit"]
  tmux_confirm_gate -> tmux_tester [label="Retry"]

  memory_writer -> done
}
