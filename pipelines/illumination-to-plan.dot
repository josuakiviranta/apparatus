digraph illumination_to_plan {
  goal="Triage an illumination into an approved design doc and implementation plan"
  headless_safe=false
  inputs="meditations_dir, specs_dir, plans_dir"

  start [shape=Mdiamond]

  verifier [agent="verifier", json_schema_file="schemas/verifier.json", produces="preferred_label, illumination_path, summary, explanation", prompt="You are a verification agent for the ralph-cli project.\n\n## Task\n\n1. Run glob on $meditations_dir/illuminations/*.md to list all illumination files.\n2. If no files exist, return preferred_label: empty, illumination_path: empty, summary: No illuminations found, explanation: The illuminations directory is empty.\n3. Pick ONE illumination to verify. Read it carefully.\n4. Spawn subagents (up to 50) to verify the illumination against the current codebase:\n   - Check src/ to verify technical claims about code behavior\n   - Check specs/*.md to verify claims about specifications\n   - Verify the issue described has NOT already been fixed\n5. Return your structured verdict.\n\n## Verification Criteria\n- Still relevant: the issue or gap described in the illumination exists in the current code\n- Technically accurate: the claims about code behavior match what the source code actually does\n- Both must be true for preferred_label: true\n\n## Rules\n- Do NOT modify any project files\n- Read only — no edits, no deletions, no new files"]

  explain_removal [agent="change-explainer", prompt="Read the illumination at $illumination_path.\n\nVerifier explanation: $explanation\n\nIn ONE sentence, explain to the user why this illumination is no longer valid or technically inaccurate. Be specific — reference the code or spec that contradicts it.\n\nDo NOT modify any project files."]

  remove_gate [shape=hexagon, label="Remove this illumination?\n$illumination_path\n\n$explanation"]

  delete_file [type="tool", cwd="$project", tool_command="rm $illumination_path"]

  mark_archived [agent="task", prompt="Call mcp__illumination__mark_archived with filename from $illumination_path (basename only) and reason summarizing why the illumination is being archived (use context from $summary). Return the JSON result."]

  mark_dispatched [agent="task", prompt="Call mcp__illumination__mark_dispatched with filename from $illumination_path (basename only) and plan_path set to $design_doc_path. Return the JSON result."]

  explainer [agent="change-explainer", prompt="Read the illumination at $illumination_path.\n\nVerifier summary: $summary\nVerifier explanation: $explanation\n\nExplain to the user in simple, clear terms:\n1. What would change in the codebase\n2. Why this change matters\n3. What files or modules would be affected\n\nKeep it concise — aim for 3-5 sentences. Do NOT modify any project files."]

  approval_gate [shape=hexagon, label="Proceed with plan?\n\nIllumination: $illumination_path\nSummary: $summary"]

  chat_session [agent="chat-refiner", interactive=true, prompt="You are discussing an illumination with the user.\n\nIllumination file: $illumination_path\nSummary: $summary\nExplanation: $explanation\n\nThe user may want to:\n- Refine the scope of changes\n- Add constraints or requirements\n- Ask questions about the illumination\n- Disagree with the assessment\n\nBefore ending the conversation, write your agreed conclusions to $meditations_dir/.triage/$run_id/chat-notes.md. This file will be read by the next pipeline stage.\n\nDo NOT modify any other project files."]

  chat_summarizer [agent="task", default_refinements="", json_schema_file="schemas/chat-summarizer.json", produces="refinements, scope_changed", prompt="Read $meditations_dir/.triage/$run_id/chat-notes.md and the illumination at $illumination_path.\n\nOriginal explanation: $explanation\nPrevious refinements (if any): $refinements\n\nSummarize what was refined or changed during the interactive session. Focus on concrete changes to scope, constraints, or approach.\n\nDo NOT modify any project files."]

  design_writer [agent="design-writer", default_refinements="No interactive refinements were requested.", json_schema_file="schemas/design-writer.json", produces="design_doc_path", prompt="Write a superpowers-style design document based on the approved illumination.\n\nIllumination: $illumination_path\nSummary: $summary\nExplanation: $explanation\nRefinements: $refinements\n\n## Output\nWrite the design doc to $specs_dir/YYYY-MM-DD-<topic>-design.md where YYYY-MM-DD is today's date and <topic> is a short kebab-case name derived from the illumination.\n\nFollow the conventions of existing design docs in $specs_dir/. Include: overview, architecture, components, data flow, constraints.\n\nReturn the path to the created file in your structured output.\n\nDo NOT modify any other project files."]

  plan_writer [agent="plan-writer", prompt="Read the design doc at $design_doc_path.\n\nWrite a superpowers-style implementation plan at $plans_dir/YYYY-MM-DD-<topic>.md where the date and topic match the design doc.\n\nFollow the conventions of existing plans in $plans_dir/. Include: chunks, tasks with TDD steps, exact file paths, commit messages.\n\nDo NOT modify any other project files."]

  done [shape=Msquare]

  // Routing
  start -> verifier
  verifier -> explain_removal  [condition="preferred_label=false"]
  verifier -> explainer        [condition="preferred_label=true"]
  verifier -> done             [condition="preferred_label=empty"]

  // False path
  explain_removal -> remove_gate
  remove_gate -> done         [label="No"]
  remove_gate -> delete_file  [label="Yes"]
  delete_file -> done

  // True path
  explainer -> approval_gate
  approval_gate -> mark_archived  [label="Decline"]
  approval_gate -> design_writer [label="Approve"]
  approval_gate -> chat_session  [label="Chat"]
  mark_archived -> done

  // Chat loop
  chat_session -> chat_summarizer -> approval_gate

  // Plan writing
  design_writer -> mark_dispatched -> plan_writer -> done
}
