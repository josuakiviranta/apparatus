digraph meditate {
  inputs="steer"

  start [shape=Mdiamond];
  end   [shape=Msquare];

  read_vision [type="tool",
               cwd="$project",
               script_file="read-vision.mjs",
               produces_from_stdout=true]

  meditate [shape=box, agent="meditate", default_vision=""];

  start -> read_vision -> meditate -> end;
}
